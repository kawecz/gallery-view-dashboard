{
    "name": "obsidian-gallery-view",
    "version": "1.0.0",
    "description": "A minimalist library interface rendering folders and notes as beautiful, configurable visual cards.",
    "main": "main.js",
    "type": "module",
    "scripts": {
        "dev": "node esbuild.config.mjs",
        "build": "tsc -p . --noEmit --skipLibCheck && node esbuild.config.mjs production",
        "version": "node version-bump.mjs && git add manifest.json versions.json",
        "lint": "eslint ."
    },
    "keywords": ["obsidian", "gallery", "dashboard", "minimalist", "cards"],
    "license": "0-BSD",
    "devDependencies": {
        "@eslint/js": "9.30.1",
        "@types/node": "^22.0.0",
        "esbuild": "0.25.5",
        "eslint-plugin-obsidianmd": "0.1.9",
        "globals": "14.0.0",
        "jiti": "2.6.1",
        "tslib": "2.4.0",
        "typescript": "^5.8.3",
        "typescript-eslint": "8.35.1"
    },
    "dependencies": {
        "obsidian": "latest"
    }
}